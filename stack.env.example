# Copie este arquivo para stack.env e preencha no Portainer
# (Stack → Environment variables → carregar arquivo, ou colar o conteúdo)

SECRET_KEY=troque-por-uma-chave-segura
DEBUG=False
ALLOWED_HOSTS=portal.fgcentroeducacional.com.br,localhost
CSRF_TRUSTED_ORIGINS=https://portal.fgcentroeducacional.com.br
SITE_URL=https://portal.fgcentroeducacional.com.br

# Banco de dados (referência ao serviço "db" dentro da stack)
DB_NAME=fgcursos
DB_USER=fgcursos_user
DB_PASSWORD=senha_segura_aqui
DB_HOST=db
DB_PORT=5432

# Redis (referência ao serviço "redis" dentro da stack)
REDIS_URL=redis://redis:6379/0

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=segredo_hmac

# Mídia (S3/R2/MinIO — deixe em branco para armazenar localmente no volume)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=fgcursos-media
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# E-mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=contato@fgcursos.com.br
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=FG Cursos <contato@fgcursos.com.br>

GUNICORN_WORKERS=3
